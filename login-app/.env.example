# Zitadel API URL (without trailing slash)
ZITADEL_API_URL=http://localhost:8080

# Service user PAT for Zitadel API access
# Either set ZITADEL_SERVICE_USER_TOKEN directly or mount a file and use ZITADEL_SERVICE_USER_TOKEN_FILE
ZITADEL_SERVICE_USER_TOKEN=
ZITADEL_SERVICE_USER_TOKEN_FILE=

# Base path for the login app (empty for root, or /ui/v2/login for proxied)
NEXT_PUBLIC_BASE_PATH=

# Require email verification before login
EMAIL_VERIFICATION=false

# Whether ui_locales from OAuth requests should always override the language cookie
# ZITADEL_UI_LOCALES_OVERRIDE_COOKIE=false
